# Windrose Docker Stack — environment file
#
# DO NOT commit this file to version control.
# Copy this file to .env, fill in the values, then run:
#   docker compose up -d --build

# ---------------------------------------------------------------------------
# System
# ---------------------------------------------------------------------------

# IANA timezone — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# UID and GID of the host user that should own the server files on disk.
# Run: id -u && id -g
PUID=1000
PGID=1000

# GID of /var/run/docker.sock on your host.
# The CrowsNest container needs this to reach the Docker socket.
# Run: stat -c '%g' /var/run/docker.sock
DOCKER_GID=999

# ---------------------------------------------------------------------------
# Host paths
# ---------------------------------------------------------------------------

# Base directory on the host where Windrose server files will be stored.
# Game files are written to $USERDIR/Windrose/ and mounted into the container.
# This directory must be writable by the UID/GID specified in PUID/PGID above.
USERDIR=/path/to/server-files

# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------

# LAN IP address of the host NIC used for P2P proxy routing.
P2P_PROXY_ADDRESS=192.168.1.x

# ---------------------------------------------------------------------------
# Game server
# ---------------------------------------------------------------------------

# In-game invite code players use to join your server.
INVITE_CODE=YourInviteCode

# Server name shown in the server browser.
SERVER_NAME=MyServer

# Password players need to join (leave blank for no password).
SERVER_PASSWORD=

# Maximum number of concurrent players.
MAX_PLAYERS=4

# If true, SteamCMD will update the server files on every container start.
UPDATE_ON_START=false

# Set to false if Windrose+ is not installed.
WINDROSE_PLUS_ENABLED=true
