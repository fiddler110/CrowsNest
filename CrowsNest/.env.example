# Windrose Game Server Controller — environment file
#
# DO NOT commit this file to version control.
# Copy this file to .env and fill in the values before first run.
#
# ---------------------------------------------------------------------------
# User credentials
# ---------------------------------------------------------------------------
# One entry per user listed in VALID_USERS in app.py.
# Generate hashes with set_password.py, e.g.:
#   python set_password.py alice
#   python set_password.py bob
#
# Replace ALICE / BOB with your chosen usernames (uppercase).
ALICE_PASSWORD_HASH=
BOB_PASSWORD_HASH=

# Flask session signing key — auto-generated on first run if left blank.
SESSION_SECRET=

# ---------------------------------------------------------------------------
# Windrose+ integration (optional — enables player count and night shutdown)
# ---------------------------------------------------------------------------
# RCON password — must match the "rcon": { "password": "..." } value in
# windrose_plus.json inside your server files directory.
# See the README for instructions on locating this file and finding the password.
WINDROSE_PLUS_RCON_PASSWORD=

# Windrose+ HTTP API base URL.
# The default works for standard Docker host-networking setups.
WPLUS_HTTP_URL=http://host.docker.internal:8780

# ---------------------------------------------------------------------------
# Night shutdown (requires Windrose+ integration above)
# ---------------------------------------------------------------------------
# Discord webhook URL to notify when the server is shut down for the night.
DISCORD_WEBHOOK_URL=

# Set to false to disable the automatic night shutdown scheduler entirely.
NIGHT_SHUTDOWN_ENABLED=true

# Time window and check interval for the night shutdown (all times are local server time).
# NIGHT_SHUTDOWN_START : hour (0-23) checks begin  — default 23  (11 pm)
# NIGHT_SHUTDOWN_END   : hour (0-23) checks stop   — default 5   (5 am)
# NIGHT_SHUTDOWN_INTERVAL : minutes between checks — default 30
#   Valid intervals: 1 2 3 4 5 6 10 12 15 20 30 60
NIGHT_SHUTDOWN_START=23
NIGHT_SHUTDOWN_END=5
NIGHT_SHUTDOWN_INTERVAL=30
